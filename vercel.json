{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/demo",
      "destination": "https://godius-dashboard.vercel.app/demo"
    },
    {
      "source": "/demo/:path*",
      "destination": "https://godius-dashboard.vercel.app/demo/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://godius-dashboard.vercel.app/_next/:path*"
    },
    {
      "source": "/api/gis/:path*",
      "destination": "https://godius-dashboard.vercel.app/api/gis/:path*"
    },
    {
      "source": "/contacto",
      "destination": "https://godius-dashboard.vercel.app/contacto"
    },
    {
      "source": "/contacto/:path*",
      "destination": "https://godius-dashboard.vercel.app/contacto/:path*"
    },
    {
      "source": "/api/leads",
      "destination": "https://godius-dashboard.vercel.app/api/leads"
    }
  ]
}
